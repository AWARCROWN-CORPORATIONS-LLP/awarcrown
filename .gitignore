# Ignore system files
.DS_Store
Thumbs.db

# Ignore PHP/Node caches
*.log
*.tmp
*.cache
*.bak
*.swp
*.zip
__pycache__/
node_modules/

# Ignore IDE configs
.vscode/
.idea/

# Ignore environment and secrets
.env
.env.*
*.env
.env.local
.env.development
.env.production
credentials.json
secrets.json

# Ignore sensitive configuration files
config.php
database.php
db.php
config/*.php
config/*.json
**/db*.php
**/*config*.php
**/*database*.php

# Ignore SSL/SSH secrets
*.pem
*.key
*.crt
*.pub
*.p12
*.jks

# Ignore Composer vendor
/vendor/
